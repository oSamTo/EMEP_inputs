#!/bin/bash
#SBATCH --partition=standard
#SBATCH --qos=standard
#SBATCH --account=ceh_generic
#SBATCH --job-name=run_inputs_single
#SBATCH -o slurm/output/emep_sing_%j.out
#SBATCH -e slurm/output/emep_sing_%j.err
#SBATCH --mem=60G
#SBATCH -t 07:59:00
R CMD BATCH --no-restore --no-save run.R slurm/output/console_EMEPinputs.Rout